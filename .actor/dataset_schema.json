      "company": {
        "type": ["string", "null"],
        "title": "Company",
        "description": "Company name for job records.",
        "example": "Acme AI"
      },
      "title": {
        "type": ["string", "null"],
        "title": "Job title",
        "description": "Job title for job records.",
        "example": "Python Automation Engineer"
      },
      "location": {
        "type": ["string", "null"],
        "title": "Location",
        "description": "Job location string.",
        "example": "Bangalore"
      },
      "apply_url": {
        "type": ["string", "null"],
        "title": "Apply URL",
        "description": "Direct application URL when available.",
        "example": "https://example.com/jobs/123"
      },
      "confidence_score": {
        "type": ["number", "null"],
        "title": "Confidence score",
        "description": "Normalized confidence score for extracted record.",
        "example": 0.83
      },
      "generatedAt": {
        "type": ["string", "null"],
        "title": "Generated at",
