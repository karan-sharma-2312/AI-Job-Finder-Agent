        "fields": [
          "recordType",
          "source",
          "company",
          "title",
          "location",
          "apply_url",
          "confidence_score",
          "generatedAt",
          "counts"
        ]
      },
      "display": {
        "component": "table",
        "properties": {
          "apply_url": {
            "label": "Apply URL",
            "format": "link"
          },
          "confidence_score": {
            "label": "Confidence",
            "format": "number"
          },
